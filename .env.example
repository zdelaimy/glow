# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (legacy — kept for historical orders)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Square (legacy — kept for historical orders)
SQUARE_ACCESS_TOKEN=EAAAl...
SQUARE_LOCATION_ID=L...
SQUARE_WEBHOOK_SIGNATURE_KEY=your-webhook-signature-key
SQUARE_ENVIRONMENT=sandbox

# Braintree (legacy)
BRAINTREE_MERCHANT_ID=your-merchant-id
BRAINTREE_PUBLIC_KEY=your-public-key
BRAINTREE_PRIVATE_KEY=your-private-key
BRAINTREE_ENVIRONMENT=sandbox

# PayPal
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_ENVIRONMENT=sandbox

# PayPal Subscription Plan IDs (create these in PayPal Dashboard > Subscriptions)
NEXT_PUBLIC_PAYPAL_PLAN_PRO_MONTHLY=P-xxxxx
NEXT_PUBLIC_PAYPAL_PLAN_PRO_ANNUAL=P-xxxxx
NEXT_PUBLIC_PAYPAL_PLAN_ELITE_MONTHLY=P-xxxxx
NEXT_PUBLIC_PAYPAL_PLAN_ELITE_ANNUAL=P-xxxxx

# Founder codes (comma-separated, first 10 founders skip payment)
FOUNDER_CODES=GLOW001,GLOW002,GLOW003,GLOW004,GLOW005,GLOW006,GLOW007,GLOW008,GLOW009,GLOW010

# App
NEXT_PUBLIC_APP_URL=https://glowlabs.nyc

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_WORKSPACE_URL=your-workspace.slack.com
SLACK_ORDERS_CHANNEL=#orders
